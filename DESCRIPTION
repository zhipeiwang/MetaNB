Package: MetaNB
Type: Package
Title: Meta-Analysis of Net Benefit and Value-of-Information
Version: 0.0.0.9000
Authors@R: c(person(given = "Kim (Zhipei)", family = "Wang", role = "aut", 
                    email = "wzpskye@gmail.com", comment="https://orcid.org/0009-0002-9839-9138"), 
            person(given = "Junfeng", family = "Wang", role = c("aut", "cre"), 
